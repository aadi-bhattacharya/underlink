<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Underlink TX / RX"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Mode label + toggle -->
    <TextView
        android:id="@+id/tvModeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mode"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp" />

    <Switch
        android:id="@+id/switchMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TX Mode"
        app:layout_constraintBaseline_toBaselineOf="@id/tvModeLabel"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status bar — shows what's happening right now -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Initialising..."
        android:textSize="12sp"
        android:textStyle="italic"
        android:textColor="#888888"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvModeLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp" />

    <!-- TX: message input -->
    <EditText
        android:id="@+id/etTx"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Type message to send"
        android:inputType="text"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- TX: Send + PTT buttons -->
    <Button
        android:id="@+id/btnSend"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Send"
        app:layout_constraintTop_toBottomOf="@id/etTx"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnPtt"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp" />

    <Button
        android:id="@+id/btnPtt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="SPEAK"
        android:minHeight="80dp"
        app:layout_constraintTop_toBottomOf="@id/etTx"
        app:layout_constraintStart_toEndOf="@id/btnSend"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp" />

    <!-- RX: Recalibrate button — visible in both modes, only active in RX -->
    <Button
        android:id="@+id/btnRecalibrate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recalibrate"
        android:textSize="12sp"
        android:enabled="false"
        app:layout_constraintTop_toBottomOf="@id/btnSend"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- RX log label -->
    <TextView
        android:id="@+id/tvRxLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RX Log"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/btnRecalibrate"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp" />

    <!-- Scrolling log -->
    <ScrollView
        android:id="@+id/scrollRx"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvRxLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvQualityLabel"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvRxLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(waiting for RX...)\n"
            android:textSize="12sp"
            android:fontFamily="monospace" />

    </ScrollView>

    <!-- Link quality bar at bottom -->
    <TextView
        android:id="@+id/tvQualityLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Link quality"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/progressQuality" />

    <ProgressBar
        android:id="@+id/progressQuality"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
