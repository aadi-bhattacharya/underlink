<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:padding="16dp">

    <!-- Hidden legacy views to avoid "unresolved reference" if old MainActivity code still expects them -->
    <TextureView
        android:id="@+id/textureView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnTestFlash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Test Flash"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Underlink TX / RX"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Mode switch row -->
    <TextView
        android:id="@+id/tvModeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mode"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp" />

    <Switch
        android:id="@+id/switchMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PTT"
        app:layout_constraintBaseline_toBaselineOf="@id/tvModeLabel"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- TX input -->
    <EditText
        android:id="@+id/etTx"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Type message to send"
        android:inputType="text"
        app:layout_constraintTop_toBottomOf="@id/tvModeLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <!-- Send / PTT buttons -->
    <Button
        android:id="@+id/btnSend"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Send"
        app:layout_constraintTop_toBottomOf="@id/etTx"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnPtt"
        app:layout_constraintHorizontal_chainStyle="spread"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="8dp" />

    <Button
        android:id="@+id/btnPtt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="PTT (Hold)"
        app:layout_constraintTop_toBottomOf="@id/etTx"
        app:layout_constraintStart_toEndOf="@id/btnSend"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="8dp" />

    <!-- RX Log -->
    <TextView
        android:id="@+id/tvRxLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RX Log"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/btnSend"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <ScrollView
        android:id="@+id/scrollRx"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvRxLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvQualityLabel"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvRxLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(waiting for RX...)"
            android:textSize="13sp" />
    </ScrollView>

    <!-- Quality bar -->
    <TextView
        android:id="@+id/tvQualityLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Link quality"
        android:textStyle="bold"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/progressQuality" />

    <ProgressBar
        android:id="@+id/progressQuality"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
